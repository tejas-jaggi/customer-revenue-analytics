        <mxCell id="factSnapshot" value="&lt;b&gt;Fact_Customer_Monthly_Snapshot&lt;/b&gt;&lt;br&gt;PK snapshot_key&lt;br&gt;FK customer_key&lt;br&gt;FK snapshot_month_date_key&lt;br&gt;customer_age_days&lt;br&gt;months_since_first_purchase&lt;br&gt;recency_days&lt;br&gt;orders_last_30_days, orders_last_90_days&lt;br&gt;cumulative_orders_to_date&lt;br&gt;cumulative_net_revenue_to_date&lt;br&gt;rolling_12mo_net_revenue&lt;br&gt;is_active_flag, is_repeat_customer_flag&lt;br&gt;churn_risk_flag" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
