        <mxCell id="dimCampaign" value="&lt;b&gt;Dim_Campaign&lt;/b&gt;&lt;br&gt;PK campaign_key&lt;br&gt;campaign_name, campaign_type&lt;br&gt;start_date, end_date&lt;br&gt;discount_depth, season&lt;br&gt;target_audience&lt;br&gt;is_active_flag" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
