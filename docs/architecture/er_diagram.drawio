        <mxCell id="dimReturnReason" value="&lt;b&gt;Dim_Return_Reason&lt;/b&gt;&lt;br&gt;PK return_reason_key&lt;br&gt;reason_code&lt;br&gt;reason_description&lt;br&gt;is_controllable" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="720" y="740" width="220" height="120" as="geometry" />
