<mxfile host="app.diagrams.net" agent="claude" version="24.0.0">
  <diagram name="Customer Revenue Analytics - ER Diagram" id="cra-er-diagram">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Customer Revenue Analytics — Solstice Apparel — ER Diagram (Fact Constellation)" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="-40" width="700" height="40" as="geometry" />
        </mxCell>

        <!-- LEFT COLUMN: DIMENSIONS -->
        <mxCell id="dimCustomer" value="&lt;b&gt;Dim_Customer&lt;/b&gt;&lt;br&gt;PK customer_key&lt;br&gt;customer_id (NK)&lt;br&gt;first_name, last_name, email&lt;br&gt;signup_date&lt;br&gt;birth_year (v1.1)&lt;br&gt;FK acquisition_channel_key&lt;br&gt;FK home_geography_key" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="220" height="165" as="geometry" />
        </mxCell>

        <mxCell id="dimGeography" value="&lt;b&gt;Dim_Geography&lt;/b&gt;&lt;br&gt;PK geography_key&lt;br&gt;city&lt;br&gt;state&lt;br&gt;region&lt;br&gt;country&lt;br&gt;postal_code (v1.1)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="220" height="135" as="geometry" />
        </mxCell>

        <mxCell id="dimMarketingChannel" value="&lt;b&gt;Dim_Marketing_Channel&lt;/b&gt;&lt;br&gt;PK marketing_channel_key&lt;br&gt;channel_name&lt;br&gt;channel_category" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="220" height="110" as="geometry" />
        </mxCell>

        <mxCell id="dimDate" value="&lt;b&gt;Dim_Date&lt;/b&gt;&lt;br&gt;PK date_key&lt;br&gt;full_date, year, quarter&lt;br&gt;month, month_name, week_of_year&lt;br&gt;day_of_week, day_name&lt;br&gt;is_weekend, holiday_flag&lt;br&gt;fiscal_quarter, fiscal_year&lt;br&gt;season, campaign_period_flag" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="40" y="740" width="220" height="170" as="geometry" />
        </mxCell>

        <!-- CENTER COLUMN: FACTS -->
        <mxCell id="factOrders" value="&lt;b&gt;Fact_Orders&lt;/b&gt;&lt;br&gt;PK order_key&lt;br&gt;order_id (degenerate, NK)&lt;br&gt;FK customer_key&lt;br&gt;FK order_date_key&lt;br&gt;FK sales_channel_key&lt;br&gt;FK geography_key&lt;br&gt;FK campaign_key (nullable)&lt;br&gt;FK acquisition_channel_key&lt;br&gt;gross_revenue, discount_amount&lt;br&gt;net_revenue, shipping_revenue&lt;br&gt;is_first_order" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="40" width="240" height="220" as="geometry" />
        </mxCell>

        <mxCell id="factOrderLines" value="&lt;b&gt;Fact_Order_Lines&lt;/b&gt;&lt;br&gt;PK order_line_key&lt;br&gt;FK order_key&lt;br&gt;FK customer_key (denorm)&lt;br&gt;FK product_key&lt;br&gt;FK order_date_key&lt;br&gt;quantity, unit_price&lt;br&gt;gross_line_revenue&lt;br&gt;discount_amount&lt;br&gt;net_line_revenue, unit_cost" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="320" width="240" height="200" as="geometry" />
        </mxCell>

        <mxCell id="factReturns" value="&lt;b&gt;Fact_Returns&lt;/b&gt;&lt;br&gt;PK return_key&lt;br&gt;FK order_key&lt;br&gt;FK order_line_key&lt;br&gt;FK customer_key&lt;br&gt;FK product_key&lt;br&gt;FK return_date_key&lt;br&gt;FK return_reason_key&lt;br&gt;return_quantity&lt;br&gt;return_amount, restocking_fee&lt;br&gt;refund_completed_flag (v1.1)" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="580" width="240" height="215" as="geometry" />
